# ===== Server =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ===== Database (MySQL via XAMPP/phpMyAdmin) =====
DB_NAME=eventy
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql

# ===== Redis (Docker) =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Auth (JWT) =====
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# ===== Email (Nodemailer) =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Eventy <no-reply@eventy.com>

# ===== Stripe =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# سر إنشاء حساب المالك عبر POST /api/auth/owner-setup
OWNER_SETUP_SECRET=change_me_to_a_secret
